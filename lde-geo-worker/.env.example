# LDE GPS/Benzol worker — variabile (valorile reale stau DOAR pe VPS în .env, niciodată în git)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# tracker = platforma GPS (Postgres)
TRACKER_HOST=
TRACKER_PORT=5432
TRACKER_USER=
TRACKER_PASS=
TRACKER_DB=tracker
# benzol = motorină la pompă (MySQL)
BENZOL_HOST=
BENZOL_PORT=23306
BENZOL_USER=
BENZOL_PASS=
# fișier localități OSM Moldova (geojsonseq, extras cu osmium)
PLACES_FILE=/root/lde-geo-worker/places.geojsonseq
# TLX (proiect АЗС, Supabase separat) — preț vânzare motorină; service_role (prices e RLS deny-all)
TLX_SUPABASE_URL=
TLX_SERVICE_KEY=
# Wialon API oficial (platforma GPS = white-label global.gpsauto.md → backend hst-api.wialon.com)
WIALON_TOKEN=
# WIALON_HOST=https://hst-api.wialon.com  (default; de suprascris doar dacă se schimbă backend-ul)
