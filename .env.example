# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Anthropic (Claude OCR pentru Z-rapoarte)
ANTHROPIC_API_KEY=sk-ant-...

# Web Auth
AUTH_SECRET=generate-a-random-secret-here-min-32-chars

# Admin Seed (used by seed script)
ADMIN_EMAIL=admin@translux.md
ADMIN_PASSWORD=change-me-in-production

# Bot username (for invite links)
NEXT_PUBLIC_BOT_USERNAME=TransluxBot

# Timezone
TZ=Europe/Chisinau
