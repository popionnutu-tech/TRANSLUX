# Copiază în `.env` (la rădăcină) și completează valorile reale.
# Pentru DEZVOLTARE LOCALĂ (Claude Code) e nevoie minim de: SUPABASE_* + AUTH_SECRET.
# Restul (bot, voice, deploy) doar dacă lucrezi pe acele părți.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Anthropic (Claude OCR pentru Z-rapoarte)
ANTHROPIC_API_KEY=sk-ant-...

# Web Auth (generează un secret random, min 32 caractere)
AUTH_SECRET=generate-a-random-secret-here-min-32-chars

# Verificare login (NU au fallback hardcodat — fără ele login-ul /verificare eșuează închis)
VERIFICARE_USER=set-a-username
VERIFICARE_PASS=set-a-strong-password

# Admin Seed (used by seed script)
ADMIN_EMAIL=admin@translux.md
ADMIN_PASSWORD=change-me-in-production

# Bot username (for invite links)
NEXT_PUBLIC_BOT_USERNAME=TransluxBot

# Voice AI (ElevenLabs)
VOICE_API_KEY=generate-a-random-api-key
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=your-agent-id

# Timezone
TZ=Europe/Chisinau

# Deploy only (NU e necesar pentru dezvoltare locală)
RAILWAY_TOKEN=your-railway-project-token
