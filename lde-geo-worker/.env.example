# LDE GPS/Benzol worker — variabile (valorile reale stau DOAR pe VPS în .env, niciodată în git)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# tracker = platforma GPS (Postgres)
TRACKER_HOST=
TRACKER_PORT=5432
TRACKER_USER=
TRACKER_PASS=
TRACKER_DB=tracker
# benzol = motorină la pompă (MySQL)
BENZOL_HOST=
BENZOL_PORT=23306
BENZOL_USER=
BENZOL_PASS=
# fișier localități OSM Moldova (geojsonseq, extras cu osmium)
PLACES_FILE=/root/lde-geo-worker/places.geojsonseq
